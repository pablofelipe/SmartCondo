# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=smartcondo
DB_USER=postgres
DB_PASSWORD=change-me

# JWT signing key: base64-encoded, must decode to at least 32 bytes.
# Generate one with: openssl rand -base64 32
JWT_KEY=change-me

# Comma-separated list of origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:3000

# SMTP settings used for account confirmation and password reset e-mails
EmailSettings__FromEmail=noreply@example.com
EmailSettings__FromPassword=change-me
EmailSettings__SmtpServer=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__EnableSsl=true

# Initial administrator account created by the migration endpoint
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Shared key required by POST /api/v1/migration/migrate (X-Migration-Auth header)
MIGRATION_AUTH_KEY=change-me

# Base URL of the frontend, used to build password-reset links
FRONTEND_BASE_URL=http://localhost:3000
